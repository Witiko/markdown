\markdownSetup {
  lineBlocks = true,
  pipeTables = true,
}
<<<
| line
| line
  line
| line

| Right | Left | Default | Center |
|------:|:-----|---------|:------:|
|   12  |  12  |    12   |    12  |
|  123  |  123 |   123   |   123  |
|    1  |    1 |     1   |     1  |
>>>
BEGIN document
lineBlockBegin
hardLineBreak
hardLineBreak
lineBlockEnd
interblockSeparator
interblockSeparator
BEGIN table (4 rows, 4 columns)
- caption: 
- alignment of column 1: r
- alignment of column 2: l
- alignment of column 3: d
- alignment of column 4: c
- row 1, column 1: Right
- row 1, column 2: Left
- row 1, column 3: Default
- row 1, column 4: Center
- row 2, column 1: 12
- row 2, column 2: 12
- row 2, column 3: 12
- row 2, column 4: 12
- row 3, column 1: 123
- row 3, column 2: 123
- row 3, column 3: 123
- row 3, column 4: 123
- row 4, column 1: 1
- row 4, column 2: 1
- row 4, column 3: 1
- row 4, column 4: 1
END table
END document
