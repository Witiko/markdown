\markdownSetup{htmlOutput=basic}
<<<
This test ensures that the `htmlOutput` option correctly propagates through the
plain TeX interface and that, when set to `basic`, it produces basic
coarse-grained renderers for display and inline HTML.

<!-- block comment -->

<script>alert('hi')</script>

<div>
hello
</div>

<br/>

foo <b>bar</b> baz<br/> <!-- bam --> <!doctype html> <?php echo "foo"; ?> <![CDATA[ bar ]]>
>>>
BEGIN document
codeSpan: htmlOutput
softLineBreak
codeSpan: basic
softLineBreak
interblockSeparator
inputBlockHtmlElement: b3ffb66dd7e08481fe6b45f4a11c8552.verbatim
interblockSeparator
inputBlockHtmlElement: dba3735d95b8e26c1629e504c873955b.verbatim
interblockSeparator
inputBlockHtmlElement: 5ed18adb8bdfa2141d18971defaa62ac.verbatim
interblockSeparator
inputBlockHtmlElement: ???.verbatim
interblockSeparator
inlineHtmlTag: <b>
inlineHtmlTag: </b>
inlineHtmlTag: <br/>
inlineHtmlComment: bam
inlineHtmlTag: <!doctype html>
inlineHtmlTag: <?php echo "foo"; ?>
inlineHtmlTag: <![CDATA[ bar ]]>
END document
